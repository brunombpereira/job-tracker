# Copy this file to .env and fill in real values

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/jobtracker_development

# Rails
RAILS_MASTER_KEY=
SECRET_KEY_BASE=

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Shared-secret API token. When set, every API request must carry it as
# `Authorization: Bearer <token>` and the frontend shows a login screen.
# Leave BLANK for local dev (the API stays open). REQUIRED in production —
# without it the deployed API, including the personal CV/profile data, is
# public. Generate one with: ruby -rsecurerandom -e 'puts SecureRandom.hex(24)'
API_ACCESS_TOKEN=
