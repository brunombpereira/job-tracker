# Created by https://www.toptal.com/developers/gitignore

/.bundle/
/log/*
/tmp/*
/storage/*
!/log/.keep
!/tmp/.keep
!/storage/.keep
/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key
/config/credentials/*.key

# Ignore .env files
.env
.env.*
!.env.example

# Coverage
/coverage/

# RSpec persistence
/spec/examples.txt

# ProfileController storage — track only the structure README so the
# personal PDFs/docx/templates never end up in the public repo.
!/storage/profile/
!/storage/profile/README.md
/storage/profile/cv/
/storage/profile/cover_letters/
